{
  "editor.formatOnSave": false,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "editor.defaultFormatter": "dbaeumer.vscode-eslint",
  "[vue]": {
    "editor.defaultFormatter": "Vue.volar"
  },
  "[typescript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "eslint.validate": ["vue", "typescript", "javascript"],
  "eslint.workingDirectories": [{ "mode": "auto" }],
  "commandOnAllFiles.commands": {
    "Remove All Comments": {
      "command": "remove-comments.removeAllComments",
      "includeFileExtensions": [".vue", ".ts", ".js", ".css", ".html"],
      "excludeFolders": ["node_modules", "dist"]
    }
  },
  "i18n-ally.localesPaths": [
    "src/core/locales"
  ],
  "i18n-ally.displayLanguage": "es",
  "i18n-ally.sourceLanguage": "en",
  "i18n-ally.enabledFrameworks": [
    "vue"
  ],
  "i18n-ally.keystyle": "nested",
  "i18n-ally.pathMatcher": "{locale}.ts",
  "i18n-ally.ignoredLocales": ["i18n"],
  "i18n-ally.enabledParsers": [
    "ts",
    "json"
  ],
  "workbench.colorCustomizations": {
    "titleBar.activeBackground": "#000249",
    "titleBar.inactiveBackground": "#000249"
  }
}